# EditorConfig: https://editorconfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
spelling_language = en-US
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[.git*]
indent_style = tab
trim_trailing_whitespace = unset
insert_final_newline = unset

[*.sh]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 80
shell_variant = bash

[*.{cmd,bat,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab

[{Justfile,justfile,.justfile,.justfile.user}]
indent_style = space
indent_size = 2

[*.{py,pyi}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100
docstring_fill_column = 99 # Docstring line wrapping

[.venvs/**.py]
indent_size = unset
indent_style = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
end_of_line = unset

[{Containerfile,Dockerfile,Dockerfile.template,Dockerfile.sample}]
indent_style = space
indent_size = 4

[*.json]
indent_style = space
indent_size = 2

[*.{yml,yaml,yamllint,bu,butane}]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = false
max_line_length = 80

[*.{conf,ini,cfg}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false
insert_final_newline = true

[*.{xml,plist}]
indent_style = space
indent_size = 2
insert_final_newline = ignore

[*.less]
indent_style = space
indent_size = 2

[*.{csv,tsv}]
indent_style = space
indent_size = 4
tab_width = 4
trim_trailing_whitespace = false
insert_final_newline = true

[*.{md,mdx,rst}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[LICENSE]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
